<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zoll Pro - Free Version</title>
    <style>
        body { font-family: sans-serif; background: #f0f2f5; margin:0; padding-top:60px; }
        .fb-header { background: #4267b2; color:white; padding:10px; position:fixed; top:0; width:100%; display:flex; justify-content:space-around; align-items:center; z-index:1000; }
        .card { background:white; margin:10px; padding:15px; border-radius:8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .scroll-news { height: 100px; overflow-y: scroll; border-left: 3px solid #4267b2; padding-left:10px; }
        #chat-window { height: 150px; overflow-y: auto; background: #eee; padding:5px; margin-bottom:5px; }
        canvas { background:#000; display:block; margin:auto; width:100%; max-width:300px; height:150px; }
        input, select, button { width:100%; padding:10px; margin:5px 0; border-radius:5px; border:1px solid #ccc; }
        button { background:#4267b2; color:white; font-weight:bold; cursor:pointer; }
    </style>
</head>
<body>

<div class="fb-header">
    <span><b>ZollApp</b></span>
    <input type="text" placeholder="Suche User/ID..." style="width:50%; margin:0;">
    <span>ID: 1.001</span>
</div>

<div class="card">
    <h3>Aktuelle Zoll-News</h3>
    <div class="scroll-news">
        <% news.forEach(n => { %> <p><b><%= n.d %>:</b> <%= n.t %></p> <% }) %>
    </div>
</div>

<div class="card">
    <h3>Zollrechner & HS-Finder</h3>
    <input type="number" id="val" placeholder="Warenwert">
    <select id="curr"><option value="USD">USD</option><option value="GBP">GBP</option></select>
    <button onclick="calc()">Berechnen</button>
    <p id="res"></p>
    <hr>
    <input type="text" placeholder="HS-Code / Ware suchen...">
    <button>In Online-Datenbank suchen</button>
</div>

<div class="card">
    <h3>Online Chat (Echtzeit)</h3>
    <div id="chat-window"></div>
    <input type="text" id="m" placeholder="Nachricht...">
    <button onclick="send()">Senden</button>
</div>

<div class="card">
    <h3>Spielebereich (5 Browsergames)</h3>
    <select id="gameSelect" onchange="gameLoad()">
        <option value="1">1. Zoll-Snake</option>
        <option value="2">2. Steuer-Clicker</option>
        <option value="3">3. Border-Pong</option>
        <option value="4">4. Waren-Memory</option>
        <option value="5">5. Zoll-Labyrinth</option>
    </select>
    <canvas id="gameCanvas"></canvas>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    function send() { 
        const m = document.getElementById('m').value;
        socket.emit('chatMsg', m); 
        document.getElementById('m').value = '';
    }
    socket.on('chatMsg', m => { 
        document.getElementById('chat-window').innerHTML += `<div><b>User:</b> ${m}</div>`;
    });

    async function calc() {
        const v = document.getElementById('val').value;
        const c = document.getElementById('curr').value;
        const r = await fetch('/api/cur');
        const data = await r.json();
        document.getElementById('res').innerText = "Wert: " + (v / data[c]).toFixed(2) + " EUR";
    }

    function gameLoad() {
        const ctx = document.getElementById('gameCanvas').getContext('2d');
        ctx.fillStyle = "white";
        ctx.clearRect(0,0,300,150);
        ctx.fillText("Spiel startet...", 110, 75);
    }
</script>
</body>
</html>
